{
  "format_version": "1.8.0",
  "minecraft:attachable": {
    "description": {
      "identifier": "minecraft:diamond_helmet",
      "materials": {
        "default": "armor",
        "enchanted": "armor_enchanted"
      },
      "textures": {
        "default": "textures/models/armor/diamond_1",
        "enchanted": "textures/misc/enchanted_actor_glint",
        "baby": "textures/models/armor/diamond_baby"
      },
      "geometry": {
        "default": "geometry.humanoid.armor.helmet",
        "baby": "geometry.humanoid.baby.armor.helmet"
      },
      "scripts": {
        "parent_setup": "variable.helmet_layer_visible = 0.0;",
        "pre_animation": [
          "variable.use_baby_geo = query.is_baby && c.owning_entity->v.use_dedicated_baby_armor;"
        ]
      },
      "render_controllers": [ "controller.render.armor.v2" ]
    }
  }
}
